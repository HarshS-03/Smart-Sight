# Auto detect text files and normalize line endings to LF
* text=auto

# Code files
*.py text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf

# Binary files
*.sqlite3 binary
*.pyc binary
*.so binary
